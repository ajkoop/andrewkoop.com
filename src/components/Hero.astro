---
import { profile } from "../data/profile";

const principles = [
  {
    title: "Build Capacity",
    text: "Technology should expand an organization’s capacity—not its complexity.",
  },
  {
    title: "Practice Stewardship",
    text: "Every public dollar should be treated as if it directly affects a family.",
  },
  {
    title: "Develop People",
    text: "Leadership means helping people build the confidence to solve the next problem themselves.",
  },
];
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">Andrew J. Koop</p>

      <h1>Building Capacity Through Connection</h1>

      <p class="hero-lead">
        I help educational organizations connect people, systems, and ideas so they can
        work more effectively, make better decisions, and stay focused on the people they serve.
      </p>

<p class="hero-note">
  My work sits at the intersection of technology, leadership, and public
  service. I’m most interested in building systems—and developing
  people—that leave an organization stronger than I found it.
</p>

<p class="hero-note">
  I’ve spent my career helping people untangle difficult problems, reconnect
  work that has become disconnected, and build the confidence to carry
  increasingly heavy things.
</p>
    </div>

    <div class="portrait-wrap">
      <img
        src="/images/andrew-headshot.png"
        alt="Andrew J. Koop"
        class="portrait"
      />
    </div>
  </div>

  <div class="principles-grid">
    {
      principles.map((principle) => (
        <article class="principle">
          <h2>{principle.title}</h2>
          <p>{principle.text}</p>
        </article>
      ))
    }
  </div>
</section>